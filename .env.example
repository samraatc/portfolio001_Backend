# =====================================================
# Backend Environment Variables
# Copy this file to `.env` and fill in real values.
# =====================================================

# Application
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# CORS - comma separated list of allowed origins.
# In development, the API also auto-allows any localhost / 127.0.0.1 / private LAN IP
# (10.x, 172.16-31.x, 192.168.x) on any port — you only need to fill this for production.
# Example for LAN testing: http://10.84.51.26:5173,http://10.84.51.26:5174
CLIENT_ORIGINS=http://localhost:5173,http://localhost:5174

# MongoDB
MONGO_URI=mongodb://localhost:27017/portfolio

# JWT
JWT_SECRET=replace-with-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Mail (contact form notifications - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Portfolio <no-reply@portfolio.dev>"
MAIL_TO=

# Admin seeding (one-off)
SEED_ADMIN_EMAIL=bishnu001@gmail.com
SEED_ADMIN_PASSWORD=Bishnu001
SEED_ADMIN_NAME=Admin
